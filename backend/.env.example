DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/autobooker
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# ── 国内服务商 ──────────────────────────────────────────────

# 千问 DashScope（OpenAI 兼容对话 + 向量嵌入；万相等原生 API）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
CHAT_MODEL=qwen-max
CHAT_MODEL_FAST=qwen-turbo

# FIGURE 插图（架构示意/场景插画）：zeelin | openai | wanx | auto
FIGURE_IMAGE_PROVIDER=auto
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_TIMEOUT_SEC=180
OPENAI_IMAGE_MAX_RETRIES=2
# OpenAI 超时/连不上时自动回退万相（需 DASHSCOPE_API_KEY）
FIGURE_IMAGE_FALLBACK_WANX=true

# 通义万相（仅 FIGURE_IMAGE_PROVIDER=wanx 时；原生异步 API）
IMAGE_MODEL=wanx-v1
DASHSCOPE_NATIVE_API_BASE=https://dashscope.aliyuncs.com/api/v1

# DeepSeek（默认对话/大纲/章节；未配 DEEPSEEK_API_KEY 时回退千问）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Kimi（Moonshot）
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# 豆包（火山方舟；模型名可为推理接入点 ID，如 ep-xxxx）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 百度千帆
BAIDU_API_KEY=
BAIDU_BASE_URL=https://qianfan.baidubce.com/v2

# 智灵网关（统一模型接口，OpenAI 兼容）
ZEELIN_API_KEY=
ZEELIN_BASE_URL=https://getways-jumu.zeelin.cn/v1
ZEELIN_CHAT_MODEL=DeepSeek-V4-Pro
# 可选：gpt-image-2, wan2.7-image, wan2.2-t2i-flash, qwen-image-edit-plus,
#      Doubao-Seedream-5.0-lite, Doubao-seedream-4-5, seededit_v3.0
ZEELIN_IMAGE_MODEL=gpt-image-2
ZEELIN_IMAGE_SIZE=auto

# ── 国外服务商 ──────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude（Anthropic 原生 API）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Gemini（Google OpenAI 兼容端点，可选对话）
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Grok（xAI）
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# ── 通用 ────────────────────────────────────────────────────
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=1.0
UPLOAD_DIR=./uploads

# Production: keep both false — uploads/figures are legacy dev/migration only.
# Business files persist in PostgreSQL binary_assets (db://binary_assets/{id}).
ASSETS_COMPAT_STATIC=false
ALLOW_LOCAL_BUSINESS_STORAGE=false

# Graphviz（流程图渲染；可选，默认自动探测 C:\Program Files\Graphviz\bin）
# GRAPHVIZ_BIN_DIR=C:\Program Files\Graphviz\bin

# Unified source search. Missing Tavily credentials keep web sources unavailable.
SOURCE_SEARCH_ENABLED=true
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
SOURCE_SEARCH_TIMEOUT_SEC=12
SOURCE_SEARCH_ALLOW_DDG_FALLBACK=true
