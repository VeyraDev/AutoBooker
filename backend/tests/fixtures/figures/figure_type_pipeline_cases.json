[
  {
    "id": "chart",
    "subtype_hint": "chart",
    "prompt": "生成一张柱状图，对比三种部署方案的平均延迟：vLLM 为 42ms，TGI 为 58ms，普通 FastAPI 为 95ms，突出 vLLM 延迟最低。",
    "expected_effect": "真实数值柱状图，横轴为部署方案，纵轴为平均延迟，不能编造数据，输出可读的 chart PNG/SVG。",
    "expected": {
      "route": "chart",
      "diagram_subtype": "chart",
      "renderer": "structured.chart",
      "render_mode": "structured_chart",
      "required_spec_fields": ["labels", "values"]
    }
  },
  {
